{
  "id": "bg-shell",
  "name": "Background Shell",
  "version": "1.0.0",
  "description": "Run and manage background shell processes with interactive monitoring",
  "tier": "bundled",
  "requires": { "platform": ">=2.29.0" },
  "provides": {
    "tools": ["bg_shell"],
    "commands": ["bg"],
    "hooks": ["session_shutdown", "session_compact", "session_tree", "session_switch", "before_agent_start", "session_start", "turn_end", "agent_end", "tool_execution_end"],
    "shortcuts": ["Ctrl+Alt+B"]
  }
}
